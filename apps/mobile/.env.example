# Mobile app environment.
# Only EXPO_PUBLIC_* variables are exposed to the bundle — anything here ships
# to the device and is effectively public. NEVER place the service-role key here.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=
EXPO_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=
